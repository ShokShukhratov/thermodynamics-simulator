#                               Section 1: Model and Classes

class Particle:
    def __init__(self,x,y,vx,vy,radius,mass,color):
        self.x=x
        self.y=y
        self.vx=vx
        self.vy=vy
        self.radius=radius
        self.mass=mass
        self.color=color

    def updatePosition(self):
        self.x+=self.vx
        self.y+=self.vy
    
    def bounceOffWalls(self,container):
        
        #Purpose: reflect particles velocity when hits wall and returns total amount of 
        #momentum transferred which container will use to determine pressure changes
        
        momentumTransferred=0
        
        #left wall
        if self.x-self.radius<=container.left:
            self.x=container.left+self.radius
            self.vx=abs(self.vx)
            momentumTransferred+=2*self.mass*abs(self.vx)
        
        #right wall
        elif self.x+self.radius>=container.right:
            self.x=container.right-self.radius
            self.vx=-abs(self.vx)
            momentumTransferred+=2*self.mass*abs(self.vx)
        
        #top wall
        if self.y-self.radius<=container.top:
            self.y=container.top+self.radius
            self.vy=abs(self.vy)
            momentumTransferred+=2*self.mass*abs(self.vy)
        
        #bottom wall
        elif self.y+self.radius>=container.bottom:
            self.y=container.bottom-self.radius
            self.vy=-abs(self.vy)
            momentumTransferred+=2*self.mass*abs(self.vy)
        
        return momentumTransferred
        
    def getSpeed(self):
        #magnitude of velocity components
        return math.sqrt(self.vx**2+self.vy**2)
        
    def getKineticEnergy(self):
        return .5*self.mass*(self.vx**2+self.vy**2)

class Container:
    #tracks its own size, position, and uses collisions to determine pressure inside of it
    
    FIXED_LEFT=40
    FIXED_TOP=5
    FIXED_BOTTOM=200
    
    def __init__(self,width):
        self.left=Container.FIXED_LEFT
        self.top=Container.FIXED_TOP
        self.bottom=Container.FIXED_BOTTOM
        self.right=self.left+width
        
        #Accumulated momentum from collisions since last pressure reset
        self.accumulatedImpulse=0
        #amount of steps from last pressure calculation
        self.stepsSinceReset=0
        # pressure value shown to user
        self.pressure=0
        
        #amount of steps between each pressure calculation
        self.PRESSURE_INTERVAL=30
    
    @property
    def width(self):
        return self.right-self.left
    
    @property
    def height(self):
        return self.bottom-self.top
    
    @property
    def volume(self):
        #In 2d depth is a constant
        return self.width*self.height
    
    def addImpulse(self,impulse):
        #will be called by each particle when it bounces of wall
        self.accumulatedImpulse+=impulse
    
    #this function was from ClaudeCode
    def updatePressure(self):
        #compute average pressure after every PRESSURE-INTERVAL steps which will be total impulse
        #per time divided by volume to get per unit area units
        
        self.stepsSinceReset+=1
        if self.stepsSinceReset>self.PRESSURE_INTERVAL:
            rawPressure=self.accumulatedImpulse/self.PRESSURE_INTERVAL
            #make result easy to see and more stable to actual change
            self.pressure=.7*self.pressure+.3*rawPressure
            self.accumulatedImpulse=0
            self.stepsSinceReset=0
    
    def setWidth(self,newWidth):
        MIN_WIDTH=60
        MAX_WIDTH=270
        newWidth=max(MIN_WIDTH,min(MAX_WIDTH,newWidth))
        self.right=self.left+newWidth
    
    def containsPoint(self,x,y):
        return self.left<=x<=self.right and self.top<=y<=self.bottom

#                               Section 2-Physics Helper Functions
def distance(p1,p2):
    dx=p2.x-p1.x
    dy=p2.y-p1.y
    return math.sqrt(dx**2+dy**2)

def regulateElasticCollisions(p1,p2):
    #computes new velocities after each collision
    #Algorithm: Find normal vector from their centers, project current velocities onto the normal
    
    #conserves both kinetic energy and momentum
    
    dx=p2.x-p1.x
    dy=p2.y-p1.y
    dist=math.sqrt(dx**2+dy**2)
    
    if dist==0:
        return 
    
    #unit normal vector
    normalX=dx/dist
    normalY=dy/dist
    
    #relative velocity of p1 to p2
    relativeVX=p1.vx-p2.vx
    relativeVY=p1.vy-p2.vy
    
    #how much of the relative velcity is along the normal
    relativeSpeedAlongNormal=relativeVX*normalX+relativeVY*normalY
    
    if relativeSpeedAlongNormal>0:
        return False #particles are moving away from eah other, so no collision
    
    #impulse factor for elastic collisions
    impulseScalar=(2*relativeSpeedAlongNormal)/(p1.mass+p2.mass)
    
    #update velocity using impulse calculation
    p1.vx-=impulseScalar*p2.mass*normalX
    p1.vy-=impulseScalar*p2.mass*normalY
    p2.vx+=impulseScalar*p1.mass*normalX
    p2.vy+=impulseScalar*p1.mass*normalY

    #ensure no particles are going through each other
    overlap=(p1.radius+p2.radius)-dist
    if overlap>0:
        correction=overlap/2
        p1.x-=correction*normalX
        p1.y-=correction*normalY
        p2.x+=correction*normalX
        p2.y+=correction*normalY
        
    return True
    
def checkParticleCollisions(particles,app):
    #check every unique particles of particles for overlap and handle the collisions
    n=len(particles)
    for i in range(n):
        for j in range(i+1,n):
            p1=particles[i]
            p2=particles[j]
            if distance(p1,p2)<p1.radius+p2.radius:
                collided=regulateElasticCollisions(p1,p2)
                if collided:
                    app.collisionCount+=1

def computeAverageKineticEnergies(particles):
    if len(particles)==0:
        return 0
    totalKE=sum(p.getKineticEnergy() for p in particles)
    return totalKE/len(particles)

def computeTemperature(particles):
    avgKE=computeAverageKineticEnergies(particles)
    #this part is from Claude
    ##scale factor chosen so starting speed around 2 gives temp to 200
    return avgKE*50

def getSpeedColor(speed,minSpeed,maxSpeed):
    #slow=blue
    #medium=white
    #fast=red
    
    if maxSpeed==minSpeed:
        return 'white'
    
    #keep speed from a scale of 0 to 1 for convenience in changing colors
    #these calculations are from claude
    t=(speed-minSpeed)/(maxSpeed-minSpeed)
    t=max(0,min(1,t))
    
    #color changes based on speed
    if t<.35:
        return 'dodgerBlue'
    elif t>.65:
        return 'red'
    else:
        return 'white'

def heatParticles(particles,energyBoost):
    #add KE to every particle by increasing velocities
    #increasing speed by factor>1 will be same as increase in temperature
    
    for p in particles:
        p.vx*=energyBoost
        p.vy*=energyBoost

def coolParticles(particles,energyReduction):
    #remove KE from particles by decreasing speeds (energy reduction gotta be between 0 and 1)
    for p in particles:
        p.vx*=energyReduction
        p.vy*=energyReduction

def keepParticlesInsideContainer(particles,container):
    #the resizing of container shouldn't allow particles to be outside of it
    for p in particles:
        margin=p.radius
        p.x=max(container.left+margin,min(container.right-margin,p.x))
        p.y=max(container.top+margin,min(container.bottom-margin,p.y))

def makeParticle(container):
    radius=5
    margin=radius+2
    
    #generate random position inside the walls
    x=random.uniform(container.left+margin,container.right-margin)
    y=random.uniform(container.top+margin,container.bottom-margin)
    
    #angle calculation gotten from claude
    angle=random.uniform(0,2*math.pi)
    speed=random.uniform(1.5,3)
    vx=speed*math.cos(angle)
    vy=speed*math.sin(angle)
    
    return Particle(x,y,vx,vy,radius,mass=1,color='white')

def computeSpeedStdDev(particles):
    # a low standard deviation will mean most particles have similar speed and thermal equilibrium is reaches
    #measures how spread out the speeds are
    if len(particles)<2:
        return 0
    
    speeds=[p.getSpeed() for p in particles]
    avgSpeed=sum(speeds)/len(particles)
    variance=sum((s-avgSpeed)**2 for s in speeds)/len(speeds)
    return math.sqrt(variance)

