#                                       Section 5 -Controllers
def onStep(app):
    if app.paused:
        return
    
    for _ in range(app.stepsPerFrame):
        physicsStep(app)
    
    updateHistogram(app)
    
    if app.heatFlash>1:
        app.heatFlash-=1
    
    if app.coolFlash>1:
        app.coolFlash-=1
        
    app.stepCount+=1
    
def physicsStep(app):
    # move the particles, cause collisions and collect impulse, pressure gets updated
    for p in app.particles:
        p.updatePosition()
        impulse=p.bounceOffWalls(app.container)
        app.container.addImpulse(impulse)
    
    checkParticleCollisions(app.particles,app)
    app.container.updatePressure()

def capParticleSpeed(particles,maxSpeed=12):
    for p in particles:
        speed=p.getSpeed()
        if speed>maxSpeed:
            p.vx=p.vx/speed*maxSpeed
            p.vy=p.vy/speed*maxSpeed

def floorParticleSpeed(particles,minSpeed=.5):
    for p in particles:
        speed=p.getSpeed()
        if speed<minSpeed:
            p.vx=p.vx/speed*minSpeed
            p.vy=p.vy/speed*minSpeed
            
            

def updateHistogram(app):
    #each bin counts how many particles fall in a speed range
    bins=[0]*app.histogramBins
    for p in app.particles:
        speed=p.getSpeed()
        #map speed to bin index(this was by claude)
        binIndex=int(speed/app.MAX_HISTOGRAM_SPEED *app.histogramBins)
        binIndex=min(binIndex,app.histogramBins-1)
        bins[binIndex]+=1
    app.histogramData=bins
    
def onMousePress(app,mouseX,mouseY):
    app.showInstructions=False
    
    #checking slider info
    handleRadius=10
    if (abs(mouseX-app.sliderX)<=handleRadius and abs(mouseY-app.sliderHandleY)<=handleRadius):
        app.draggingSlider=True
    
    #checking heat button
    if pointInRect(mouseX,mouseY,app.heatButtonX,app.heatButtonY,app.heatButtonW,app.heatButtonH):
        heatParticles(app.particles,energyBoost=1.15)
        app.heatFlash=1
    
    #checking cool button
    if pointInRect(mouseX,mouseY,app.coolButtonX,app.coolButtonY,app.coolButtonW,app.coolButtonH):
        coolParticles(app.particles,energyReduction=.85)
        app.coolFlash=1

    
def onMouseDrag(app,mouseX,mouseY):
    #this condition was by claude
    if app.draggingSlider:
        newHandleY=max(app.sliderTrackTop,min(app.sliderTrackBottom,mouseY))
        app.sliderHandleY=newHandleY
        
        #slider UP=more volume, slider Down=less volume
        t=(newHandleY-app.sliderTrackTop)/(app.sliderTrackBottom-app.sliderTrackTop)
        newWidth=270-int(t*210)
        app.container.setWidth(newWidth)
        
        #checking to see if particle is outside border(this was by me)
        keepParticlesInsideContainer(app.particles,app.container)

def onMouseRelease(app,mouseX,mouseY):
    app.draggingSlider=False
    app.heatFlash=0
    app.coolFlash=0

def onKeyPress(app,key):
    #keyboard shortcuts:
    #space-pause/resume, r-reset,a-add 5 particles,d-remove 5 particles,h-heat,c-cool
    
    if key=='space':
        app.paused=not app.paused
    
    elif key=='r' or key=='R':
        onAppStart(app)
    
    elif key=='a' or key=='A':
        for _ in range(5):
            if len(app.particles)<80:
                app.particles.append(makeParticle(app.container))
    
    elif key=='d' or key =='D':
        for _ in range(5):
            if len(app.particles)>2:
                app.particles.pop()
    
    elif key=='h' or key=='H':
        heatParticles(app.particles,energyBoost=1.15)
        app.heatFlash=1

    elif key=='c' or key=='C':
        coolParticles(app.particles,energyReduction=.85)
        app.coolFlash=1
    
    elif key=='g' or key=='G':
        for _ in range(38):
            app.particles.append(makeParticle(app.container))
    
    elif key=='j' or key=='J':
        #compress to minimum value
        app.container.setWidth(60)
        app.sliderHandleY=app.sliderTrackBottom
        keepParticlesInsideContainer(app.particles,app.container)
    
    elif key=='k' or key=="K":
        #heat dramatically
        for _ in range(4):
            heatParticles(app.particles,energyBoost=1.3)
    
    elif key=='l' or key=='L':
        #cool dramatically
        for _ in range(4):
            coolParticles(app.particles,energyReduction=.9)
        
def onKeyRelease(app,key):
    if key=='h':
        app.heatFlash=0
    elif key=='c':
        app.coolFlash=0

def pointInRect(px,py,rx,ry,rw,rh):
    return rx<=px<=rx+rw and ry<=py<=ry+rh

def main():
    runApp()
main()
