def drawHistogram(app):
    #a live speed histogram in which bars will estimate a Maxwell-Boltzmann distribution(bell shaped curve skewed to right)
    
    #layout
    histTop=225
    histBottom=350
    histLeft=14
    histRight=266
    histHeight=histBottom-histTop
    histWidth=histRight-histLeft
    
    #background
    drawRect(histLeft,histTop,histWidth,histHeight+5,fill=rgb(10,10,20),border='gray',borderWidth=1)
    drawLabel('SPEED DISTRIBUTION (Maxwell-Boltzmann)',histLeft+histWidth//2,histTop+8,size=10,fill='cyan',font='monospace',bold=True)
    
    #bars
    bins=app.histogramData
    maxBinCount=max(bins) if max(bins)>0 else 1
    
    binCount=len(bins)
    barAreaLeft=histLeft+5
    barAreaWidth=histWidth-10
    barW=barAreaWidth/binCount
    barMaxH=histHeight-25 #leaving room for title
    
    #this loop statement was from claude
    for i,count in enumerate(bins):
        barH=int((count/maxBinCount)*barMaxH)
        barX=barAreaLeft+i*barW
        barY=histBottom-barH
        
        #color bars by speed(from claude)
        t=i/(binCount-1) if binCount>1 else 0
        r=int(t*255)
        b=int((1-t)*255)
        barColor=rgb(r,80,b)
        
        if barH>0:
            drawRect(barX+1,barY,barW-2,barH,fill=barColor,opacity=85)
        
    #axis label
    drawLabel('SLOW',barAreaLeft+10,histBottom+15,size=10,fill='dodgerBlue',bold=True)
    drawLabel('FAST',barAreaLeft+barAreaWidth-20,histBottom+15,size=10,fill='red',bold=True)
    drawLabel('X: Speed | Y: No. of Particles',histLeft+histWidth//2,histTop-10,size=10,fill='white',font='monospace',bold=True)
    
    #equilibrium indicator
    stdDev=computeSpeedStdDev(app.particles)
    #threshold tuned so it only triggers when it is settled
    #threshold given by Claude
    if stdDev<1.2 and len(app.particles)>=5:
        drawRect(histLeft+80,histTop+140,80,14,fill=rgb(0,40,0),border='lime',borderWidth=1)
        drawLabel('EQUILIBRIUM',histLeft+histWidth//2-6,histBottom+22,size=8,fill='lime',bold=True,font='monospace')
        
